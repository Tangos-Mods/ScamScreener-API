# Minimal docker-compose config.
# Add more TRAINING_HUB_* variables only when you need to override the app defaults from README.md.
# Docker-specific values like the internal MariaDB host, Mailpit host, project root, and trusted proxy IP
# are injected by docker-compose.yml and intentionally do not live here.

# Public entrypoint handled by Caddy.
# Local default:
CADDY_SITE_ADDRESS=http://localhost
# Optional if ports 80/443 are already in use:
# CADDY_HTTP_PORT=8080
# CADDY_HTTPS_PORT=8443

# For a public Caddy domain with the bundled internal MariaDB, use:
# TRAINING_HUB_ENV=staging
# TRAINING_HUB_ALLOWED_HOSTS=hub.example.com
# TRAINING_HUB_ENFORCE_HTTPS=true
TRAINING_HUB_ENV=development
TRAINING_HUB_ALLOWED_HOSTS=localhost,127.0.0.1
TRAINING_HUB_ENFORCE_HTTPS=false

# Required secrets.
TRAINING_HUB_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
TRAINING_HUB_DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
TRAINING_HUB_DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# First-account bootstrap.
TRAINING_HUB_ADMIN_USERNAMES=admin
# Optional, informational only.
TRAINING_HUB_ADMIN_EMAILS=

# Optional local mail flows via Mailpit.
TRAINING_HUB_PASSWORD_RESET_SEND_EMAIL=false
TRAINING_HUB_ADMIN_MFA_REQUIRED=false
TRAINING_HUB_SMTP_FROM_EMAIL=no-reply@scamscreener.local

# Optional real SMTP override for a public server:
# TRAINING_HUB_SMTP_HOST=smtp.example.com
# TRAINING_HUB_SMTP_PORT=587
# TRAINING_HUB_SMTP_USERNAME=
# TRAINING_HUB_SMTP_PASSWORD=
# TRAINING_HUB_SMTP_USE_STARTTLS=true

# One-time server promotion:
# ./scripts/promote_to_production.sh
