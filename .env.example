# Copy this file to `.env` and configure all placeholders before first production start.

# Runtime profile: development | staging | production
TRAINING_HUB_ENV=production

TRAINING_HUB_HOST=0.0.0.0
TRAINING_HUB_PORT=8080
TRAINING_HUB_ALLOWED_HOSTS=scamscreener.example.com

TRAINING_HUB_DB_DRIVER=mariadb
# Optional full DSN override, e.g. mariadb://user:pass@host:3306/dbname?ssl_mode=verify-full&ssl_ca=/path/ca.pem
TRAINING_HUB_DATABASE_URL=
TRAINING_HUB_DB_HOST=mariadb
TRAINING_HUB_DB_PORT=3306
TRAINING_HUB_DB_NAME=scamscreener_hub
TRAINING_HUB_DB_USER=scamscreener
TRAINING_HUB_DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
# Only used by docker-compose MariaDB container:
TRAINING_HUB_DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD
TRAINING_HUB_DB_REQUIRE_TLS=true
TRAINING_HUB_DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
TRAINING_HUB_DB_SSL_CERT=
TRAINING_HUB_DB_SSL_KEY=
TRAINING_HUB_DB_SSL_VERIFY_HOSTNAME=true

# Required: secret for cryptographic token hashing/signing.
TRAINING_HUB_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

# Session lifetime for logged in users.
TRAINING_HUB_SESSION_TTL_MINUTES=720

# Session binding: keep UA binding enabled in production.
TRAINING_HUB_SESSION_BIND_IP=false
TRAINING_HUB_SESSION_BIND_USER_AGENT=true

# Registration policy: open | invite | closed
TRAINING_HUB_REGISTRATION_MODE=open
# Required when REGISTRATION_MODE=invite
TRAINING_HUB_REGISTRATION_INVITE_CODE=

# Password reset configuration.
TRAINING_HUB_PASSWORD_RESET_TTL_MINUTES=30
# Must stay false in production.
TRAINING_HUB_PASSWORD_RESET_SHOW_TOKEN=false
TRAINING_HUB_PASSWORD_RESET_SEND_EMAIL=true
TRAINING_HUB_SMTP_HOST=smtp.example.com
TRAINING_HUB_SMTP_PORT=587
TRAINING_HUB_SMTP_USERNAME=
TRAINING_HUB_SMTP_PASSWORD=
TRAINING_HUB_SMTP_FROM_EMAIL=no-reply@scamscreener.example.com
TRAINING_HUB_SMTP_USE_TLS=false
TRAINING_HUB_SMTP_USE_STARTTLS=true

# Require MFA code for admin logins (code sent via SMTP).
TRAINING_HUB_ADMIN_MFA_REQUIRED=true
TRAINING_HUB_ADMIN_MFA_TTL_MINUTES=30
TRAINING_HUB_ADMIN_MFA_MAX_ATTEMPTS=5

# Production hardening flags.
TRAINING_HUB_ENFORCE_HTTPS=true
TRAINING_HUB_ENABLE_RATE_LIMIT=true
TRAINING_HUB_ENFORCE_ORIGIN_CHECK=true

# Max accepted upload size in bytes.
TRAINING_HUB_MAX_UPLOAD_BYTES=5242880

# Download rate limits (per account, per minute).
TRAINING_HUB_MAX_UPLOAD_DOWNLOADS_PER_MINUTE_PER_USER=60
TRAINING_HUB_MAX_BUNDLE_DOWNLOADS_PER_MINUTE_PER_USER=30

# Per-day quotas (UTC day window) for uploads.
TRAINING_HUB_MAX_UPLOADS_PER_DAY_PER_USER=40
TRAINING_HUB_MAX_UPLOAD_BYTES_PER_DAY_PER_USER=209715200
TRAINING_HUB_MAX_UPLOAD_CASES_PER_DAY_PER_USER=20000
TRAINING_HUB_MAX_UPLOADS_PER_DAY_PER_IP=120
TRAINING_HUB_GLOBAL_UPLOAD_STORAGE_CAP_BYTES=5368709120

# Retention cleanup windows.
TRAINING_HUB_RETENTION_SESSIONS_DAYS=30
TRAINING_HUB_RETENTION_PASSWORD_RESET_DAYS=7
TRAINING_HUB_RETENTION_AUDIT_LOGS_DAYS=180
TRAINING_HUB_RETENTION_UPLOADS_DAYS=365
TRAINING_HUB_RETENTION_BUNDLES_DAYS=365
TRAINING_HUB_RETENTION_BACKUPS_DAYS=30
TRAINING_HUB_RETENTION_RATE_LIMIT_DAYS=7
TRAINING_HUB_RETENTION_AUTO_ENABLED=true
TRAINING_HUB_RETENTION_AUTO_INTERVAL_MINUTES=1440

# Max accepted uploaded backup archive size for restore.
TRAINING_HUB_BACKUP_RESTORE_MAX_BYTES=536870912

# Alerting window + thresholds (used for metrics and audit alert events).
TRAINING_HUB_SECURITY_ALERT_WINDOW_MINUTES=15
TRAINING_HUB_SECURITY_ALERT_COOLDOWN_MINUTES=15
TRAINING_HUB_SECURITY_ALERT_FAILED_LOGIN_THRESHOLD=10
TRAINING_HUB_SECURITY_ALERT_MFA_FAILED_THRESHOLD=6
TRAINING_HUB_SECURITY_ALERT_PASSWORD_RESET_THRESHOLD=10

# Where sqlite + uploaded files + generated bundles are stored.
TRAINING_HUB_STORAGE_DIR=./data

# Optional comma-separated allowlist for admin bootstrap.
# Email allowlist is informational only (no automatic admin grant).
TRAINING_HUB_ADMIN_EMAILS=
# Required for first registration bootstrap (first account must match one username here).
TRAINING_HUB_ADMIN_USERNAMES=
# Comma-separated proxy IPs/hosts allowed to provide X-Forwarded-Proto and X-Forwarded-For.
TRAINING_HUB_TRUSTED_PROXIES=127.0.0.1

# Reserved for future use. Current server mode only builds merged bundles.
TRAINING_HUB_PIPELINE_COMMAND=

# Reserved for future use.
TRAINING_HUB_PROJECT_ROOT=
